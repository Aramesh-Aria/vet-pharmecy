# Copy to .env and fill in. Never commit .env (see .gitignore).

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Local dev defaults to SQLite if unset. In production (RunFlare) set the
# Postgres URL provided by the attached database service:
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Payments (ADR-0005) — pay-at-pickup at launch; online gateway in Phase 5.
PAYMENTS_BACKEND=payments.backends.manual.ManualPickupBackend
# Flip to True (post-e-Namad) to switch checkout to online payment:
PAYMENTS_ONLINE_ENABLED=False
# PAYMENTS_ONLINE_BACKEND=payments.backends.zarinpal.ZarinpalBackend
# SITE_BASE_URL=https://example.ir          # used to build the gateway callback
# ZARINPAL_MERCHANT_ID=your-merchant-id
# ZARINPAL_SANDBOX=True

# Production-only TLS/security
# SECURE_SSL_REDIRECT=True
# CSRF_TRUSTED_ORIGINS=https://example.ir

# Email (Phase 2)
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@example.ir

# SMS gateway — Iran-reachable only, never Twilio (ADR-0003).
# Dev default is the console backend. In production:
# SMS_BACKEND=notifications.backends.kavenegar.KavenegarSMSBackend
# SMS_API_KEY=your-kavenegar-api-key
# SMS_SENDER=your-line-number
