# Copy to .env and fill in. Never commit .env (see .gitignore).

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Local dev defaults to SQLite if unset. In production (RunFlare) create a
# PostgreSQL service (16.2 recommended) and point DATABASE_URL at it. The host is
# the Postgres service's name in your RunFlare project (e.g. vet-db). URL-encode
# any special characters in the password.
# DATABASE_URL=postgres://USER:PASSWORD@vet-db:5432/DBNAME

# --- RunFlare production env (set these in the RunFlare dashboard) ------------
# DJANGO_SETTINGS_MODULE=config.settings.prod
# DEBUG=False
# SECRET_KEY=<a long random string>
# ALLOWED_HOSTS=vet-pharmecy.runflare.run          # add your custom domain too
# CSRF_TRUSTED_ORIGINS defaults to https://<each ALLOWED_HOST>; override if needed
# Static + media live under /public (a disk mounted at /app/public). Run
# `python manage.py collectstatic --noinput` and `migrate` at RUNTIME (start
# command), after the disk is mounted — see README.

# Payments (ADR-0005) — pay-at-pickup at launch; online gateway in Phase 5.
PAYMENTS_BACKEND=payments.backends.manual.ManualPickupBackend
# Flip to True (post-e-Namad) to switch checkout to online payment:
PAYMENTS_ONLINE_ENABLED=False
# PAYMENTS_ONLINE_BACKEND=payments.backends.zarinpal.ZarinpalBackend
# SITE_BASE_URL=https://example.ir          # used to build the gateway callback
# ZARINPAL_MERCHANT_ID=your-merchant-id
# ZARINPAL_SANDBOX=True

# Production-only TLS/security
# SECURE_SSL_REDIRECT=True
# CSRF_TRUSTED_ORIGINS=https://example.ir

# Email (Phase 2)
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@example.ir

# SMS gateway — Iran-reachable only, never Twilio (ADR-0003).
# Dev default is the console backend. In production:
# SMS_BACKEND=notifications.backends.kavenegar.KavenegarSMSBackend
# SMS_API_KEY=your-kavenegar-api-key
# SMS_SENDER=your-line-number
